WITH CTE AS (
    SELECT
        Sys.ResourceID,
        sys.Name0 AS HostName,
        sys.user_name0 AS UserName,
        sys.Build01,
        sys.BuildExt,
        sys.operatingSystem0,
        Sys.Distinguished_Name0 AS AD_OU_Path,
        Sys.User_Name0,
        usr.cn,
        usr.company,
        usr.department,
        usr.Distinguished_Name0,
        usr.Full_User_Name0,
        usr.givenName,
        usr.Mail0,
        usr.manager,
        usr.Name0,
        (VLD.Size0 / 1024) AS 'Hard Disk Capacity(GB)',
        (VLD.FreeSpace0 / 1024) AS 'Free Disk Space(GB)',
        ((VPM.TotalPhysicalMemory0 / 1024) / 1000) AS 'TotalRAMSize(GB)',
        vos.Organization0,
        vcs.manufacturer0,
        vcs.Model0,
        VSE.SerialNumber0,
        ISNULL(uei.UpgExProp0, 'No SCCM Data') AS UpgExProp0,
        ISNULL(uei.UpgExU0, 'No SCCM Data') AS UpgExU0,
        ISNULL(UEI.Reason0, 'No SCCM Data') AS Reason0,
        ISNULL(uei.Version0, 'No SCCM Data') AS Version0,
        vos.InstallDate0 AS 'Install Date of OS',
        vos.LastBootUpTime0,
        HWSCAN.LastHWScan,
        sys.Creation_Date0 AS System_Creation_Date,
        sys.Last_Logon_Timestamp0,
        usr.AD_Object_Creation_Time0,

        ROW_NUMBER() OVER (
            PARTITION BY sys.Name0
            ORDER BY vos.LastBootUpTime0 DESC
        ) AS rn

    FROM v_R_System AS sys

    LEFT JOIN v_FullCollectionMembership fcm 
        ON SYS.ResourceID = fcm.ResourceID

    LEFT JOIN v_GS_COMPUTER_SYSTEM vcs
        ON sys.ResourceID = vcs.ResourceID

    LEFT JOIN v_GS_OPERATING_SYSTEM vos
        ON sys.ResourceID = vos.ResourceID

    LEFT JOIN v_GS_LOGICAL_DISK VLD
        ON sys.ResourceID = VLD.ResourceID

    LEFT JOIN v_GS_Workstation_Status HWSCAN
        ON sys.ResourceID = HWSCAN.ResourceID

    LEFT JOIN v_GS_X86_PC_MEMORY VPM
        ON sys.ResourceID = VPM.ResourceID

    LEFT JOIN v_GS_SYSTEM_ENCLOSURE VSE
        ON sys.ResourceID = VSE.ResourceID

    LEFT JOIN v_GS_UPGRADE_EXPERIENCE_INDICATORS uei
        ON sys.ResourceID = uei.ResourceID
        AND uei.Version0 = 'GE24H2'

    LEFT JOIN v_R_User USR
        ON SYS.User_Name0 = USR.User_Name0

    WHERE 
        FCM.CollectionID = 'ACG0001F'
        AND VLD.Description LIKE '%Local Fixed Disk%'
)

SELECT *
FROM CTE
WHERE rn = 1
ORDER BY System_Creation_Date;
