$Session = New-Object -ComObject Microsoft.Update.Session
$Searcher = $Session.CreateUpdateSearcher()

$history = $Searcher.QueryHistory(0,2000)

$history | Select-Object Date, Title, ResultCode | Format-Table -AutoSize

$cutoff = (Get-Date).AddMonths(-3)

$history | Where-Object { $_.Date -ge $cutoff } |
Select-Object Date, Title, ResultCode |
Sort-Object Date -Descending






$Applications = Get-CMApplication

$Outfile = "C:\temp\Applications.csv"

ForEach ($Element in $Applications) {
    $xml = [xml]$Element.SDMPackageXML
    
    $csv = New-Object PSObject -Property @{
        # Direct object properties
        'Name'      = $Element.Name
        'Version'   = $Element.Version
        'CreatedBy' = $Element.CreatedBy
        'CreatedOn' = $Element.CreatedOn

        # SDMPackageXML derived properties
        'Location'  = $xml.AppMgmtDigest.DeploymentType.Installer.Contents.Content.Location
        # Easy to add more XML properties here later, e.g:
        # 'DeploymentType' = $xml.AppMgmtDigest.DeploymentType.Title.'#text'
        # 'Technology'     = $xml.AppMgmtDigest.DeploymentType.Installer.Technology
    }
    
    $csv | Select-Object 'Name', 'Version', 'CreatedBy', 'CreatedOn', 'Location' | Export-Csv -Append -Path ('FileSystem::' + $Outfile) -NoTypeInformation -Encoding UTF8
}
